{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Balce Inventory",
  "version": "0.1.0",
  "identifier": "com.balceinv.app",
  "build": {
    "frontendDist": "../frontend/.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --prefix ../frontend dev",
    "beforeBuildCommand": "pnpm --prefix ../frontend generate"
  },
  "app": {
    "windows": [
      {
        "title": "Balce Inventory",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "bin/backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
